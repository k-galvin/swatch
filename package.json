{
  "name": "swatch",
  "version": "1.0.0",
  "description": "A spatial logic language for drafting, interior design, and generative floor plan visualization.",
  "type": "module",
  "main": "src/swatch.js",
  "scripts": {
    "test": "c8 node --test test/**/*.test.js",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "build-examples": "for f in examples/*.swatch; do node src/swatch.js \"$f\" svg > \"${f%.swatch}.svg\"; done"
  },
  "eslintConfig": {
    "extends": [
      "eslint:recommended",
      "prettier"
    ],
    "env": {
      "node": true,
      "es2022": true
    },
    "parserOptions": {
      "sourceType": "module"
    },
    "rules": {
      "no-unused-vars": [
        "error",
        {
          "argsIgnorePattern": "^_"
        }
      ],
      "no-constant-condition": "off"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/k-galvin/swatch.git"
  },
  "keywords": [
    "compiler",
    "dsl",
    "interior-design",
    "ohm-js"
  ],
  "author": "Kate Galvin",
  "license": "MIT",
  "dependencies": {
    "graph-stringify": "^1.1.0",
    "ohm-js": "^17.5.0"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "mocha": "^11.0.1",
    "prettier": "^3.2.5"
  }
}
